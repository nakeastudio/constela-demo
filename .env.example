# Copiá este archivo a `.env` y completá los valores de tu proyecto Supabase.
#
# Estas dos variables terminan DENTRO del bundle del navegador: Vite inyecta todo
# lo que empieza con VITE_ en tiempo de build. Eso es correcto y esperado — la
# publishable key está diseñada para ser pública.
#
# Lo que protege los datos NO es esconder la key: es imposible esconderla. Lo que
# los protege es Row Level Security activo en cada tabla, que exige un usuario
# autenticado y limita cada fila a su dueño (auth.uid() = user_id).
#
# Nunca pongas acá una service_role key ni una API key de un proveedor de IA:
# esas sí son secretas, y acabarían publicadas en el bundle.

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXX
